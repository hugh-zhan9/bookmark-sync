{
    "manifest_version": 3,
    "name": "拾页",
    "version": "1.0.0",
    "description": "Local-first bookmark synchronizer client capturing browser events.",
    "permissions": [
        "bookmarks",
        "nativeMessaging"
    ],
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "host_permissions": [
        "http://*/*",
        "https://*/*"
    ],
    "icons": {
        "32": "icons/32.png",
        "64": "icons/64.png",
        "128": "icons/128.png"
    }
}